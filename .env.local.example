# Local development environment — copy to .env.local and fill in Telegram values.
# Matches the docker-compose.yml stack (PostgreSQL + PostgREST).
#
# Usage:
#   cp .env.local.example .env.local
#   make dev          # start containers
#   make run          # start the app (migrations run automatically on startup)

# PostgREST (supabase-py talks to this)
SUPABASE_URL=http://localhost:3000

# Pre-generated service_role JWT for local dev — safe to commit, used by docker-compose only.
# Payload: {"iss":"supabase-demo","role":"service_role","exp":1983812996}
# Signed with: super-secret-jwt-token-with-at-least-32-characters
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hj04zWl196z2-SBc0

# Direct psycopg2 URL for APScheduler job store + migrations
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/postgres

# Telegram — use your real bot token and user ID even for local testing.
# The bot sends alerts to your actual Telegram chat regardless of environment.
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CREATOR_ID=your-numeric-telegram-user-id

# Circuit breaker (safe defaults for local dev)
DAILY_COST_LIMIT=2.0
MAX_DAILY_ATTEMPTS=10

# Schedule
PIPELINE_HOUR=7
