# Supabase — get from Project Settings -> API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-service-role-key-here

# Supabase session pooler URL for APScheduler SQLAlchemyJobStore
# Must use postgresql+psycopg2:// (NOT asyncpg) and port 5432 (session pooler, NOT 6543)
DATABASE_URL=postgresql+psycopg2://postgres.your-ref:your-password@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# Telegram — get bot token from BotFather, creator ID from @userinfobot
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CREATOR_ID=987654321

# Circuit breaker limits (configurable — defaults: $2/day, 10 calls/day)
DAILY_COST_LIMIT=2.0
MAX_DAILY_ATTEMPTS=10

# Pipeline schedule (hour in America/Mexico_City timezone)
PIPELINE_HOUR=7
